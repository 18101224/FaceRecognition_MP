ninja_required_version = 1.3
cxx = c++

cflags = -Wno-unused-result -Wsign-compare -Wunreachable-code -DNDEBUG -fwrapv -O2 -Wall -fPIC -O2 -isystem /Users/seominjae/anaconda3/envs/midterm/include -arch arm64 -fPIC -O2 -isystem /Users/seominjae/anaconda3/envs/midterm/include -arch arm64 -I/Users/seominjae/anaconda3/envs/midterm/lib/python3.10/site-packages/torch/include -I/Users/seominjae/anaconda3/envs/midterm/lib/python3.10/site-packages/torch/include/torch/csrc/api/include -I/Users/seominjae/anaconda3/envs/midterm/lib/python3.10/site-packages/torch/include/TH -I/Users/seominjae/anaconda3/envs/midterm/lib/python3.10/site-packages/torch/include/THC -I/Users/seominjae/anaconda3/envs/midterm/include/python3.10 -c
post_cflags = -fopenmp -O3 -DTORCH_API_INCLUDE_EXTENSION_H '-DPYBIND11_COMPILER_TYPE="_clang"' '-DPYBIND11_STDLIB="_libcpp"' '-DPYBIND11_BUILD_ABI="_cxxabi1002"' -DTORCH_EXTENSION_NAME=rpe_index_cpp -D_GLIBCXX_USE_CXX11_ABI=0 -std=c++17
cuda_dlink_post_cflags = 
ldflags = 

rule compile
  command = $cxx -MMD -MF $out.d $cflags -c $in -o $out $post_cflags
  depfile = $out.d
  deps = gcc





